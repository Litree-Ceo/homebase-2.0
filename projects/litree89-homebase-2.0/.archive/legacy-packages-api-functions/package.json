    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/storage-blob": "^12.26.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "azure-functions-core-tools": "^4.0.6610",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
