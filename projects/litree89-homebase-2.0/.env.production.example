# Production Configuration - Revenue Optimized
# Copy to .env and fill in your actual values

# ========================================
# ENVIRONMENT
# ========================================
NODE_ENV=production
ENVIRONMENT=production

# ========================================
# DEPLOYMENT
# ========================================
API_URL=https://homebase-revenue.azurecontainerapps.io
WEB_URL=https://homebase-revenue.azurecontainerapps.io
NEXT_PUBLIC_API_URL=https://homebase-revenue.azurecontainerapps.io
NEXT_PUBLIC_ORCHESTRATOR_URL=https://homebase-revenue.azurecontainerapps.io

# ========================================
# PADDLE - PAYMENT PROCESSING (REQUIRED FOR REVENUE)
# ========================================
# Hosted checkout URLs from Paddle
NEXT_PUBLIC_PADDLE_CHECKOUT_URL_STARTER=https://buy.paddle.com/...
NEXT_PUBLIC_PADDLE_CHECKOUT_URL_PROFESSIONAL=https://buy.paddle.com/...
NEXT_PUBLIC_PADDLE_CHECKOUT_URL_ENTERPRISE=https://buy.paddle.com/...

# Paddle webhook configuration
PADDLE_WEBHOOK_SECRET=your-webhook-secret
PADDLE_ENV=sandbox

# Pricing Configuration (in cents)
PAYMENT_TIER_STARTER=1900        # $19.00/month
PAYMENT_TIER_PROFESSIONAL=4900   # $49.00/month
PAYMENT_TIER_ENTERPRISE=19900    # $199.00/month

# Payment Features
PAYMENT_PROCESSING=paddle
MONETIZATION_ENABLED=true
ENABLE_TRIALS=true
TRIAL_DAYS_STANDARD=14
TRIAL_DAYS_ENTERPRISE=30

# ========================================
# AZURE INFRASTRUCTURE
# ========================================
AZURE_SUBSCRIPTION_ID=0f95fc53-20dc-4c0d-8f76-0108222d5fb1
AZURE_RESOURCE_GROUP=litreelabstudio-rg
AZURE_KEY_VAULT=kvprodlitree14210
AZURE_COSMOS_ENDPOINT=https://litlab-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=xxx...

# ========================================
# DATABASE
# ========================================
DATABASE_URL=mongodb+srv://...  # If using MongoDB
COSMOS_ENDPOINT=https://litlab-cosmos.documents.azure.com:443/
COSMOS_KEY=xxx...
DATABASE_NAME=homebase

# ========================================
# CACHE & STORAGE
# ========================================
REDIS_URL=redis://...
STORAGE_ACCOUNT_NAME=homebasecontainers
STORAGE_ACCOUNT_KEY=xxx...

# ========================================
# SECURITY & AUTHENTICATION
# ========================================
JWT_SECRET=xxx...  # Generate: openssl rand -base64 32
SESSION_SECRET=xxx...
ENCRYPTION_KEY=xxx...

# OAuth Providers (optional, for enterprise)
GOOGLE_CLIENT_ID=xxx...
GOOGLE_CLIENT_SECRET=xxx...
GITHUB_CLIENT_ID=xxx...
GITHUB_CLIENT_SECRET=xxx...

# ========================================
# ANALYTICS & MONITORING
# ========================================
SENTRY_DSN=https://...  # For error tracking
GOOGLE_ANALYTICS_ID=UA_xxx
MIXPANEL_TOKEN=xxx...
ENABLE_ANALYTICS=true

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATION_KEY=xxx...

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================
SENDGRID_API_KEY=SG.xxx...  # For transactional emails
SENDGRID_FROM_EMAIL=noreply@homebase.app
RESEND_API_KEY=re_xxx...  # Alternative: Resend

# Email verification
EMAIL_VERIFICATION_ENABLED=true

# ========================================
# API RATE LIMITING (Protect revenue)
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60000        # 60 seconds
RATE_LIMIT_MAX_REQUESTS=100    # Per window per IP
RATE_LIMIT_MAX_REQUESTS_PREMIUM=500  # Higher limit for paid tiers

# ========================================
# LOGGING & DEBUG
# ========================================
LOG_LEVEL=info                  # 'debug', 'info', 'warn', 'error'
DEBUG_MODE=false
VERBOSE_LOGGING=false

# ========================================
# FEATURE FLAGS (Use for gradual rollout)
# ========================================
FEATURE_PADDLE_PAYMENTS=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_ANALYTICS=true
FEATURE_WHITE_LABEL=false       # Enable for enterprise
FEATURE_API_ACCESS=true
FEATURE_WEBHOOKS=true

# ========================================
# PERFORMANCE OPTIMIZATION
# ========================================
CACHE_TTL=3600
NEXT_PUBLIC_ANALYTICS_ENABLED=true
COMPRESSION_ENABLED=true
MINIFY_ENABLED=true
IMAGE_OPTIMIZATION=true

# ========================================
# REVENUE OPTIMIZATION
# ========================================
# Pricing strategy
PRICING_STRATEGY=tiered         # 'freemium', 'tiered', 'usage-based'
FREE_TIER_FEATURES=basic_dashboard,1_project
PRO_TIER_FEATURES=advanced_analytics,5_projects,team
ENTERPRISE_TIER_FEATURES=unlimited_everything,dedicated_support

# Trial settings
TRIAL_DURATION_DAYS=14
TRIAL_ENABLED=true

# Discount codes (manage in Paddle)
COUPON_CODE_LAUNCH=LAUNCH20     # 20% off for launch

# Upsell settings
UPSELL_TO_PRO_AT_PROJECT_COUNT=3  # Show upsell when users create 3+ projects
UPSELL_TO_ENTERPRISE_AT_USERS=10  # Show upsell when team hits 10 users

# ========================================
# WEBHOOK SECRETS (Internal)
# ========================================
INTERNAL_WEBHOOK_SECRET=xxx...  # For secure internal webhooks

# ========================================
# CORS & SECURITY
# ========================================
CORS_ORIGINS=https://homebase-revenue.azurecontainerapps.io,https://www.homebase-revenue.com
CSRF_PROTECTION_ENABLED=true
SECURE_COOKIES=true
HTTPS_ONLY=true

# ========================================
# EXTERNAL SERVICES (Optional)
# ========================================
# Intercom (customer support)
INTERCOM_APP_ID=xxx...

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord notifications
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/...

# ========================================
# DEPLOYMENT TRACKING
# ========================================
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_DATE=2026-01-03
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_REGION=eastus
