# ================================================================
# LitreeLabs Metaverse - Comprehensive Environment Configuration
# ================================================================
# Copy this file to .env.metaverse.example for reference
# NEVER commit actual .env files to git - they're in .gitignore
# ================================================================

# ================================================================
# AZURE CONFIGURATION
# ================================================================
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=litlabs-rg
AZURE_LOCATION=eastus
AZURE_ENVIRONMENT=dev

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=litlabsstorage
AZURE_STORAGE_ACCOUNT_KEY=your_storage_key_here
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Cosmos DB
COSMOS_ENDPOINT=https://litlabs-cosmosdb.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key_here
COSMOS_DATABASE=litlabs

# Azure Key Vault
KEY_VAULT_NAME=litlabs-keyvault
KEY_VAULT_URL=https://litlabs-keyvault.vault.azure.net/

# ================================================================
# BLOCKCHAIN / WEB3 CONFIGURATION
# ================================================================

# Ethereum Mainnet
ETH_PRIVATE_KEY=0xprivate_key_hex
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
ETH_NFT_CONTRACT=0x_contract_address

# Polygon (Recommended - low gas costs)
POLYGON_PRIVATE_KEY=0xprivate_key_hex
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
POLYGON_NFT_CONTRACT=0x_polygon_contract

# API Keys
ALCHEMY_API_KEY=your_alchemy_key
INFURA_API_KEY=your_infura_key
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_secret

# ================================================================
# SOCIAL OAUTH CONFIGURATION
# ================================================================

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret
GOOGLE_REDIRECT_URI=https://litlabs.io/auth/google/callback

# Discord OAuth
DISCORD_CLIENT_ID=your_id
DISCORD_CLIENT_SECRET=your_secret
DISCORD_REDIRECT_URI=https://litlabs.io/auth/discord/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_id
GITHUB_CLIENT_SECRET=your_secret
GITHUB_REDIRECT_URI=https://litlabs.io/auth/github/callback

# Apple Sign-in
APPLE_CLIENT_ID=com.litlabs.app
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Facebook OAuth
FACEBOOK_APP_ID=your_id
FACEBOOK_APP_SECRET=your_secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_id
LINKEDIN_CLIENT_SECRET=your_secret

# Twitch OAuth
TWITCH_CLIENT_ID=your_id
TWITCH_CLIENT_SECRET=your_secret

# Twitter/X OAuth 2.0
TWITTER_CLIENT_ID=your_id
TWITTER_CLIENT_SECRET=your_secret

# ================================================================
# PAYMENT PROCESSING
# ================================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_secret
STRIPE_CRYPTO_API_KEY=sk_test_crypto_key

# ================================================================
# AZURE AD B2C (Identity Management)
# ================================================================

AZURE_AD_B2C_TENANT=litlabs.onmicrosoft.com
AZURE_AD_B2C_CLIENT_ID=your_b2c_client_id
AZURE_AD_B2C_CLIENT_SECRET=your_b2c_client_secret
AZURE_AD_B2C_POLICY_NAME=B2C_1_SignUpSignIn_Metaverse
AZURE_AD_B2C_REDIRECT_URI=https://litlabs.io/auth/adb2c/callback

# ================================================================
# SECURITY
# ================================================================

JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRATION=3600
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRATION=604800

# ================================================================
# REAL-TIME COMMUNICATION
# ================================================================

# Azure SignalR
SIGNALR_CONNECTION_STRING=Endpoint=https://litlabs-signalr.service.signalr.net;AccessKey=...
SIGNALR_HUB_URL=https://litlabs-signalr.service.signalr.net/client/?hub=metaverse

# Agora (Voice/Video)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate

# ================================================================
# THIRD-PARTY SERVICES
# ================================================================

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@litlabs.io

# AWS S3 (Backup)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=litlabs-backups

# ================================================================
# MONITORING
# ================================================================

# Application Insights
APPINSIGHTS_INSTRUMENTATION_KEY=your_instrumentation_key
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Sentry (Error tracking)
SENTRY_DSN=https://your_key@your_org.ingest.sentry.io/your_project_id

# PostHog (Analytics)
POSTHOG_API_KEY=your_posthog_key
POSTHOG_API_HOST=https://app.posthog.com

# ================================================================
# REDIS CACHE
# ================================================================

REDIS_URL=redis://default:password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Cache TTL in seconds
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=86400

# ================================================================
# DATABASE
# ================================================================

DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000
DB_QUERY_TIMEOUT=5000
DB_LOG_QUERIES=false

# ================================================================
# APPLICATION SETTINGS
# ================================================================

NODE_ENV=development
LOG_LEVEL=info
SERVER_PORT=3000
SERVER_HOST=localhost

# Frontend URLs
VITE_API_URL=http://localhost:3000/api
VITE_SIGNALR_URL=http://localhost:3000/signalr
VITE_WEB3_NETWORK=137

# Feature flags
FEATURE_NFT_MINTING=true
FEATURE_MARKETPLACE=true
FEATURE_MULTIPLAYER=true
FEATURE_VOICE_CHAT=false
FEATURE_VR_SUPPORT=false

# Pagination
ITEMS_PER_PAGE=20
MAX_ITEMS_PER_PAGE=100

# File uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,model/gltf+json

# ================================================================
# EMAIL
# ================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=LitreeLabs
SMTP_FROM_EMAIL=noreply@litlabs.io

# ================================================================
# SECURITY & CORS
# ================================================================

CORS_ORIGINS=http://localhost:3000,https://litlabs.io
CORS_CREDENTIALS=true
CSP_ENABLED=true

# ================================================================
# RATE LIMITING
# ================================================================

RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=50

# ================================================================
# FEATURE FLAGS
# ================================================================

BETA_FEATURES_ENABLED=false
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We're upgrading. Back soon!
