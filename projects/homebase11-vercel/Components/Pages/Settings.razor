@page "/settings"
@rendermode InteractiveServer

<PageTitle>HomeBase 11 | Settings</PageTitle>

<div class="settings-container p-5">
    <div class="mb-5">
        <h1 class="brand-text">SETTINGS <span class="version">CENTER</span></h1>
        <p class="subtitle text-uppercase">Account & Preferences</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="content-glass p-4">
                <div class="settings-nav">
                    <div class="nav-item @((selectedTab == "profile") ? "active" : "")" @onclick="@(() => SelectTab("profile"))">
                        <span>👤</span> Profile
                    </div>
                    <div class="nav-item @((selectedTab == "account") ? "active" : "")" @onclick="@(() => SelectTab("account"))">
                        <span>🔐</span> Account
                    </div>
                    <div class="nav-item @((selectedTab == "privacy") ? "active" : "")" @onclick="@(() => SelectTab("privacy"))">
                        <span>🔒</span> Privacy
                    </div>
                    <div class="nav-item @(selectedTab == "notifications" ? "active" : "")" @onclick="@(() => SelectTab("notifications"))">
                        <span>🔔</span> Notifications
                    </div>
                    <div class="nav-item @(selectedTab == "appearance" ? "active" : "")" @onclick="@(() => SelectTab("appearance"))">
                        <span>🎨</span> Appearance
                    </div>
                    <div class="nav-item @(selectedTab == "security" ? "active" : "")" @onclick="@(() => SelectTab("security"))">
                        <span>🛡️</span> Security
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            @if (selectedTab == "profile")
            {
                <div class="content-glass p-4">
                    <h3 class="section-title">PROFILE SETTINGS</h3>
                    
                    <div class="profile-section mt-4">
                        <div class="avatar-section">
                            <div class="avatar-preview" style="background: linear-gradient(135deg, var(--brand-blue), var(--brand-purple))">
                                <span>AC</span>
                            </div>
                            <button class="change-avatar-btn">Change Avatar</button>
                        </div>

                        <div class="form-grid">
                            <div class="form-group">
                                <label>Display Name</label>
                                <input type="text" class="glass-input" value="Admin User" />
                            </div>
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" class="glass-input" value="admin" />
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" class="glass-input" value="admin@homebase.com" />
                            </div>
                            <div class="form-group">
                                <label>Phone</label>
                                <input type="tel" class="glass-input" value="+1 (555) 123-4567" />
                            </div>
                            <div class="form-group full-width">
                                <label>Bio</label>
                                <textarea class="glass-input" rows="3">Studio Command Center Administrator</textarea>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button class="save-btn">SAVE CHANGES</button>
                        </div>
                    </div>
                </div>
            }
            else if (selectedTab == "notifications")
            {
                <div class="content-glass p-4">
                    <h3 class="section-title">NOTIFICATION PREFERENCES</h3>
                    
                    <div class="notifications-section mt-4">
                        @foreach (var notif in notificationSettings)
                        {
                            <div class="notification-item">
                                <div class="notif-info">
                                    <div class="notif-title">@notif.Title</div>
                                    <div class="notif-desc">@notif.Description</div>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" checked="@notif.Enabled" />
                                    <span class="slider"></span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (selectedTab == "security")
            {
                <div class="content-glass p-4">
                    <h3 class="section-title">SECURITY SETTINGS</h3>
                    
                    <div class="security-section mt-4">
                        <div class="security-item">
                            <div class="security-info">
                                <div class="security-title">Password</div>
                                <div class="security-desc">Last changed 30 days ago</div>
                            </div>
                            <button class="action-btn">CHANGE</button>
                        </div>
                        <div class="security-item">
                            <div class="security-info">
                                <div class="security-title">Two-Factor Authentication</div>
                                <div class="security-desc">Add an extra layer of security</div>
                            </div>
                            <button class="action-btn outline">ENABLE</button>
                        </div>
                        <div class="security-item">
                            <div class="security-info">
                                <div class="security-title">Active Sessions</div>
                                <div class="security-desc">2 devices currently logged in</div>
                            </div>
                            <button class="action-btn outline">MANAGE</button>
                        </div>
                        <div class="security-item">
                            <div class="security-info">
                                <div class="security-title">Login History</div>
                                <div class="security-desc">View recent account activity</div>
                            </div>
                            <button class="action-btn outline">VIEW</button>
                        </div>
                    </div>

                    <div class="danger-zone mt-4">
                        <h4>DANGER ZONE</h4>
                        <div class="security-item danger">
                            <div class="security-info">
                                <div class="security-title">Delete Account</div>
                                <div class="security-desc">Permanently delete your account and data</div>
                            </div>
                            <button class="action-btn danger">DELETE</button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="content-glass p-4">
                    <h3 class="section-title">@selectedTab.ToUpper()</h3>
                    <p class="mt-4" style="color: #8b949e;">Settings for @selectedTab coming soon...</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    :root {
        --brand-blue: #00d2ff;
        --brand-purple: #9d50bb;
        --glass-bg: rgba(22, 27, 34, 0.6);
        --glass-border: rgba(255, 255, 255, 0.05);
    }

    .settings-container { color: white; }
    .brand-text { font-weight: 900; letter-spacing: -1px; }
    .brand-text .version { color: var(--brand-blue); }
    .subtitle { font-size: 0.75rem; letter-spacing: 4px; color: #8b949e; font-weight: 700; }

    .content-glass { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 20px; }
    .section-title { font-size: 0.8rem; font-weight: 800; color: #8b949e; letter-spacing: 2px; }

    .settings-nav { display: flex; flex-direction: column; gap: 4px; }
    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 600;
    }
    .nav-item:hover { background: rgba(255, 255, 255, 0.05); }
    .nav-item.active { background: rgba(0, 210, 255, 0.1); color: var(--brand-blue); }

    .profile-section {}
    .avatar-section { display: flex; align-items: center; gap: 20px; margin-bottom: 24px; }
    .avatar-preview {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: 900;
    }
    .change-avatar-btn {
        background: transparent;
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 8px 16px;
        color: white;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .change-avatar-btn:hover { border-color: var(--brand-blue); }

    .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group.full-width { grid-column: span 2; }
    .form-group label { font-size: 0.75rem; font-weight: 700; color: #8b949e; letter-spacing: 1px; }
    
    .glass-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        padding: 12px 14px;
        color: white;
        font-size: 0.95rem;
    }
    .glass-input:focus { outline: none; border-color: var(--brand-blue); }
    textarea.glass-input { resize: vertical; }

    .form-actions { margin-top: 24px; display: flex; justify-content: flex-end; }
    .save-btn {
        background: linear-gradient(135deg, var(--brand-blue), #3a7bd5);
        border: none;
        border-radius: 10px;
        padding: 12px 32px;
        color: white;
        font-weight: 800;
        cursor: pointer;
    }

    .notifications-section { display: flex; flex-direction: column; gap: 16px; }
    .notification-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
    }
    .notif-title { font-weight: 700; margin-bottom: 4px; }
    .notif-desc { font-size: 0.8rem; color: #8b949e; }

    .toggle-switch { position: relative; width: 50px; height: 26px; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background: #484f58;
        border-radius: 26px;
        transition: 0.3s;
    }
    .slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 3px;
        bottom: 3px;
        background: white;
        border-radius: 50%;
        transition: 0.3s;
    }
    .toggle-switch input:checked + .slider { background: var(--brand-blue); }
    .toggle-switch input:checked + .slider:before { transform: translateX(24px); }

    .security-section { display: flex; flex-direction: column; gap: 12px; }
    .security-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
    }
    .security-item.danger { border: 1px solid rgba(248, 81, 73, 0.3); }
    .security-title { font-weight: 700; margin-bottom: 4px; }
    .security-desc { font-size: 0.8rem; color: #8b949e; }

    .action-btn {
        background: var(--brand-blue);
        border: none;
        border-radius: 8px;
        padding: 8px 20px;
        color: white;
        font-weight: 700;
        font-size: 0.8rem;
        cursor: pointer;
    }
    .action-btn.outline { background: transparent; border: 1px solid var(--glass-border); }
    .action-btn.outline:hover { border-color: var(--brand-blue); }
    .action-btn.danger { background: #f85149; }

    .danger-zone h4 { color: #f85149; font-size: 0.8rem; letter-spacing: 2px; margin-bottom: 12px; }
</style>

@code {
    private string selectedTab = "profile";

    private List<NotificationSetting> notificationSettings = new()
    {
        new NotificationSetting { Title = "Email Notifications", Description = "Receive updates via email", Enabled = true },
        new NotificationSetting { Title = "Push Notifications", Description = "Browser push notifications", Enabled = true },
        new NotificationSetting { Title = "Friend Requests", Description = "When someone adds you", Enabled = true },
        new NotificationSetting { Title = "Messages", Description = "New message alerts", Enabled = true },
        new NotificationSetting { Title = "Events", Description = "Event reminders", Enabled = false },
        new NotificationSetting { Title = "Marketing", Description = "Promotional content", Enabled = false }
    };

    private void SelectTab(string tab)
    {
        selectedTab = tab;
    }

    public class NotificationSetting
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public bool Enabled { get; set; }
    }
}
