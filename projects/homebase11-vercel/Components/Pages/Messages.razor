@page "/messages"
@rendermode InteractiveServer

<PageTitle>HomeBase 11 | Messages</PageTitle>

<div class="messages-container">
    <div class="messages-sidebar">
        <div class="sidebar-header">
            <h2 class="brand-text">MESSAGES</h2>
            <button class="new-chat-btn" title="New Message">+</button>
        </div>
        
        <div class="search-box">
            <input type="text" class="glass-input" placeholder="Search chats..." @bind="searchQuery" />
        </div>

        <div class="chats-list">
            @foreach (var chat in chats)
            {
                <div class="chat-item @((selectedChat?.Id == chat.Id) ? "active" : "")" @onclick="() => SelectChat(chat)">
                    <div class="chat-avatar" style="background: @chat.AvatarColor">
                        @chat.Initials
                        @if (chat.Unread > 0)
                        {
                            <span class="unread-badge">@chat.Unread</span>
                        }
                    </div>
                    <div class="chat-info">
                        <div class="chat-name">@chat.Name</div>
                        <div class="chat-preview">@chat.LastMessage</div>
                    </div>
                    <div class="chat-time">@chat.Time</div>
                </div>
            }
        </div>
    </div>

    <div class="messages-main">
        @if (selectedChat != null)
        {
            <div class="chat-header">
                <div class="chat-header-info">
                    <div class="chat-avatar large" style="background: @selectedChat.AvatarColor">@selectedChat.Initials</div>
                    <div>
                        <div class="chat-name">@selectedChat.Name</div>
                        <div class="chat-status">@selectedChat.Status</div>
                    </div>
                </div>
                <div class="chat-actions">
                    <button class="action-btn" title="Call">📞</button>
                    <button class="action-btn" title="Video">📹</button>
                    <button class="action-btn" title="More">⋮</button>
                </div>
            </div>

            <div class="messages-area">
                @foreach (var message in selectedChat.Messages)
                {
                    <div class="message @message.Side">
                        <div class="message-bubble">
                            @message.Text
                        </div>
                        <div class="message-time">@message.Time</div>
                    </div>
                }
            </div>

            <div class="message-input">
                <button class="attach-btn" title="Attach">📎</button>
                <input type="text" class="glass-input" placeholder="Type a message..." @bind="newMessage" @onkeyup="HandleKeyPress" />
                <button class="send-btn" @onclick="SendMessage">➤</button>
            </div>
        }
        else
        {
            <div class="no-chat-selected">
                <div class="empty-icon">💬</div>
                <h3>Select a conversation</h3>
                <p>Choose a chat from the sidebar to start messaging</p>
            </div>
        }
    </div>
</div>

<style>
    :root {
        --brand-blue: #00d2ff;
        --brand-purple: #9d50bb;
        --glass-bg: rgba(22, 27, 34, 0.6);
        --glass-border: rgba(255, 255, 255, 0.05);
    }

    .messages-container {
        display: flex;
        height: calc(100vh - 80px);
        color: white;
    }

    .messages-sidebar {
        width: 320px;
        background: var(--glass-bg);
        border-right: 1px solid var(--glass-border);
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px;
        border-bottom: 1px solid var(--glass-border);
    }

    .brand-text { font-weight: 900; font-size: 1.1rem; letter-spacing: -1px; margin: 0; }

    .new-chat-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        background: var(--brand-blue);
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        transition: transform 0.2s;
    }
    .new-chat-btn:hover { transform: scale(1.1); }

    .search-box { padding: 16px 20px; }
    .glass-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        padding: 10px 14px;
        color: white;
        width: 100%;
        font-size: 0.9rem;
    }
    .glass-input:focus { outline: none; border-color: var(--brand-blue); }

    .chats-list { flex: 1; overflow-y: auto; padding: 0 12px; }
    
    .chat-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 4px;
    }
    .chat-item:hover { background: rgba(255, 255, 255, 0.05); }
    .chat-item.active { background: rgba(0, 210, 255, 0.1); border: 1px solid rgba(0, 210, 255, 0.2); }

    .chat-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.9rem;
        position: relative;
        flex-shrink: 0;
    }
    .chat-avatar.large { width: 48px; height: 48px; }

    .unread-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        background: var(--brand-blue);
        color: white;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 2px 6px;
        border-radius: 10px;
        min-width: 18px;
        text-align: center;
    }

    .chat-info { flex: 1; min-width: 0; }
    .chat-name { font-weight: 700; font-size: 0.95rem; margin-bottom: 2px; }
    .chat-preview { font-size: 0.8rem; color: #8b949e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-time { font-size: 0.7rem; color: #484f58; }

    .messages-main { flex: 1; display: flex; flex-direction: column; }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        background: var(--glass-bg);
        border-bottom: 1px solid var(--glass-border);
    }

    .chat-header-info { display: flex; align-items: center; gap: 14px; }
    .chat-status { font-size: 0.75rem; color: #3fb950; }

    .chat-actions { display: flex; gap: 8px; }
    .action-btn {
        background: rgba(255, 255, 255, 0.05);
        border: none;
        border-radius: 10px;
        width: 40px;
        height: 40px;
        cursor: pointer;
        font-size: 1.1rem;
        transition: all 0.2s;
    }
    .action-btn:hover { background: var(--brand-blue); }

    .messages-area { flex: 1; padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 16px; }

    .message { display: flex; flex-direction: column; max-width: 70%; }
    .message.received { align-self: flex-start; }
    .message.sent { align-self: flex-end; }

    .message-bubble {
        padding: 12px 16px;
        border-radius: 16px;
        font-size: 0.95rem;
        line-height: 1.5;
    }
    .message.received .message-bubble {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-bottom-left-radius: 4px;
    }
    .message.sent .message-bubble {
        background: linear-gradient(135deg, var(--brand-blue), #3a7bd5);
        border-bottom-right-radius: 4px;
    }

    .message-time { font-size: 0.65rem; color: #484f58; margin-top: 4px; }
    .message.sent .message-time { text-align: right; }

    .message-input {
        display: flex;
        gap: 12px;
        padding: 16px 24px;
        background: var(--glass-bg);
        border-top: 1px solid var(--glass-border);
    }
    .message-input .glass-input { flex: 1; }
    
    .attach-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        width: 44px;
        cursor: pointer;
        font-size: 1.2rem;
        transition: all 0.2s;
    }
    .attach-btn:hover { background: rgba(255, 255, 255, 0.1); }

    .send-btn {
        background: var(--brand-blue);
        border: none;
        border-radius: 10px;
        width: 44px;
        cursor: pointer;
        font-size: 1.2rem;
        transition: all 0.2s;
    }
    .send-btn:hover { transform: scale(1.05); }

    .no-chat-selected {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #8b949e;
    }
    .empty-icon { font-size: 4rem; margin-bottom: 16px; opacity: 0.5; }
    .no-chat-selected h3 { margin: 0 0 8px; color: white; }
    .no-chat-selected p { margin: 0; font-size: 0.9rem; }
</style>

@code {
    private string searchQuery = "";
    private string newMessage = "";
    private Chat? selectedChat;

    private List<Chat> chats = new()
    {
        new Chat 
        { 
            Id = 1, 
            Name = "Alex Chen", 
            Initials = "AC", 
            AvatarColor = "#3fb950",
            LastMessage = "Sure, sounds good!",
            Time = "2m",
            Unread = 0,
            Status = "Online",
            Messages = new List<Message>
            {
                new Message { Side = "received", Text = "Hey! Did you see the new update?", Time = "10:30 AM" },
                new Message { Side = "sent", Text = "Yes, it's amazing! The AI features are incredible.", Time = "10:32 AM" },
                new Message { Side = "received", Text = "I know right! Let's test it out together.", Time = "10:33 AM" },
                new Message { Side = "sent", Text = "Definitely! When are you free?", Time = "10:35 AM" },
                new Message { Side = "received", Text = "Sure, sounds good!", Time = "10:36 AM" }
            }
        },
        new Chat 
        { 
            Id = 2, 
            Name = "Sarah Miller", 
            Initials = "SM", 
            AvatarColor = "#58a6ff",
            LastMessage = "The meeting is at 3pm",
            Time = "1h",
            Unread = 2,
            Status = "In a meeting",
            Messages = new List<Message>()
        },
        new Chat 
        { 
            Id = 3, 
            Name = "Project Alpha", 
            Initials = "PA", 
            AvatarColor = "#9d50bb",
            LastMessage = "Build completed successfully",
            Time = "3h",
            Unread = 5,
            Status = "12 members",
            Messages = new List<Message>()
        },
        new Chat 
        { 
            Id = 4, 
            Name = "James Wilson", 
            Initials = "JW", 
            AvatarColor = "#d29922",
            LastMessage = "Thanks for the help!",
            Time = "Yesterday",
            Unread = 0,
            Status = "Away",
            Messages = new List<Message>()
        },
        new Chat 
        { 
            Id = 5, 
            Name = "Emma Davis", 
            Initials = "ED", 
            AvatarColor = "#f0883e",
            LastMessage = "See you tomorrow!",
            Time = "Yesterday",
            Unread = 0,
            Status = "Online",
            Messages = new List<Message>()
        }
    };

    private void SelectChat(Chat chat)
    {
        selectedChat = chat;
        chat.Unread = 0;
    }

    private void SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(newMessage) && selectedChat != null)
        {
            selectedChat.Messages.Add(new Message
            {
                Side = "sent",
                Text = newMessage,
                Time = DateTime.Now.ToString("h:mm tt")
            });
            selectedChat.LastMessage = newMessage;
            newMessage = "";
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SendMessage();
        }
    }

    private class Chat
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Initials { get; set; } = "";
        public string AvatarColor { get; set; } = "";
        public string LastMessage { get; set; } = "";
        public string Time { get; set; } = "";
        public int Unread { get; set; }
        public string Status { get; set; } = "";
        public List<Message> Messages { get; set; } = new();
    }

    private class Message
    {
        public string Side { get; set; } = "";
        public string Text { get; set; } = "";
        public string Time { get; set; } = "";
    }
}
