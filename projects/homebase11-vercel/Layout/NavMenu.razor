@namespace HomeBase11.Layout
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
<script type="module" src="@Assets["Layout/NavMenu.razor.js"]"></script>

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">HomeBase11</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" aria-label="Toggle navigation menu" aria-controls="nav-scrollable" />

<div id="nav-scrollable" class="nav-scrollable" tabindex="0">
    <nav class="nav flex-column" role="navigation" aria-label="Main navigation">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/friends">
                <span class="bi bi-people-fill" aria-hidden="true"></span> Friends
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/messages">
                <span class="bi bi-chat-dots-fill" aria-hidden="true"></span> Messages
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/groups">
                <span class="bi bi-person-bounding-box" aria-hidden="true"></span> Groups
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/events">
                <span class="bi bi-calendar-event-fill" aria-hidden="true"></span> Events
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/marketplace">
                <span class="bi bi-shop" aria-hidden="true"></span> Marketplace
            </NavLink>
        </div>
    </nav>
</div>
