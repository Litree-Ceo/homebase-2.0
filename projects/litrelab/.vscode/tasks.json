{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "run-backend",
			"type": "shell",
			"command": "uvicorn main:app --host 0.0.0.0 --port 8000",
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
		{
			"label": "Start Frontend (Astro)",
			"type": "shell",
			"command": "pnpm dev",
			"options": {
				"cwd": "${workspaceFolder}/litreelab-studio"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Open My Site",
			"type": "shell",
			"command": "start http://localhost:4321",
			"problemMatcher": []
		},
		{
			"label": "Deploy (Docker Compose)",
			"type": "shell",
			"command": "docker-compose up --build",
			"problemMatcher": []
		}
	]
}