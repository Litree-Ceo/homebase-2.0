---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Login">
  <div class="login-container">
    <div class="login-card">
      <div class="login-header">
        <h2>LiTreLab Access</h2>
        <p>Enter your credentials to continue</p>
      </div>

      <div class="login-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" placeholder="admin" autocomplete="off" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="admin" />
        </div>

        <div id="errorMessage" class="error-message"></div>

        <button id="loginBtn" class="login-btn">
          Authenticate
        </button>
      </div>
    </div>
  </div>

  <style>
    .login-container {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 200px);
    }
    .login-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 1.5rem;
      padding: 3rem;
      width: 100%;
      max-width: 450px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }
    .login-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .login-header h2 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
      color: #fff;
    }
    .login-header p {
      color: rgba(255, 255, 255, 0.5);
    }
    .form-group {
      margin-bottom: 1.5rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.9rem;
    }
    .form-group input {
      width: 100%;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 0.75rem;
      padding: 0.875rem 1rem;
      color: #fff;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .form-group input:focus {
      border-color: #e94560;
      box-shadow: 0 0 10px rgba(233, 69, 96, 0.2);
    }
    .error-message {
      color: #ff4d4d;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
      text-align: center;
      display: none;
    }
    .login-btn {
      width: 100%;
      background: linear-gradient(135deg, #e94560, #ff6b6b);
      border: none;
      border-radius: 0.75rem;
      padding: 1rem;
      color: #fff;
      font-size: 1.1rem;
      font-weight: bold;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .login-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 20px rgba(233, 69, 96, 0.4);
    }
    .login-btn:active {
      transform: translateY(0);
    }
  </style>

  <script>
    import { ApiClient } from '../lib/api';

    const loginBtn = document.getElementById('loginBtn') as HTMLButtonElement;
    const usernameInput = document.getElementById('username') as HTMLInputElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const errorMessage = document.getElementById('errorMessage') as HTMLDivElement;

    async function handleLogin() {
      const username = usernameInput.value;
      const password = passwordInput.value;

      if (!username || !password) {
        showError('Please enter both username and password');
        return;
      }

      loginBtn.disabled = true;
      loginBtn.textContent = 'Authenticating...';
      errorMessage.style.display = 'none';

      const success = await ApiClient.login(username, password);

      if (success) {
        window.location.href = '/dashboard';
      } else {
        showError('Invalid credentials or server unreachable');
        loginBtn.disabled = false;
        loginBtn.textContent = 'Authenticate';
      }
    }

    function showError(msg: string) {
      errorMessage.textContent = msg;
      errorMessage.style.display = 'block';
    }

    loginBtn?.addEventListener('click', handleLogin);
    
    // Allow Enter key to trigger login
    [usernameInput, passwordInput].forEach(el => {
      el?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleLogin();
      });
    });
  </script>
</MainLayout>
