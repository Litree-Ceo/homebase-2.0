---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Messages">
  <style>
    .placeholder {
      text-align: center;
      padding: 4rem 2rem;
    }
    .placeholder-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
    }
    .placeholder h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: #e94560;
    }
    .placeholder p {
      color: rgba(255, 255, 255, 0.7);
      max-width: 500px;
      margin: 0 auto;
      line-height: 1.6;
    }
  </style>

  <div class="placeholder">
    <div class="placeholder-icon">💬</div>
    <h2>Messages</h2>
    <p>Chat with your friends in real-time. Send text, images, and more. This feature is coming soon!</p>
  </div>
</MainLayout>
