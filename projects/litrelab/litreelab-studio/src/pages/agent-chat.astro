---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Magic Agent Terminal</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #0d0d0d;
        color: #00ff00;
        font-family: 'Courier New', Courier, monospace;
        height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .navbar {
        background: #1a1a1a;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #333;
      }
      .navbar a {
        color: #00ff00;
        text-decoration: none;
        font-weight: bold;
      }
      .navbar a:hover {
        text-decoration: underline;
      }
      .terminal-container {
        flex: 1;
        padding: 2rem;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .message {
        line-height: 1.5;
        white-space: pre-wrap;
      }
      .message.user {
        color: #00bfff;
      }
      .message.agent {
        color: #00ff00;
      }
      .message.error {
        color: #ff3333;
      }
      .input-area {
        padding: 1rem 2rem;
        background: #1a1a1a;
        display: flex;
        gap: 1rem;
        border-top: 1px solid #333;
      }
      input[type="text"] {
        flex: 1;
        background: transparent;
        border: none;
        color: #00ff00;
        font-family: inherit;
        font-size: 1rem;
        outline: none;
      }
      input[type="text"]::placeholder {
        color: #005500;
      }
      button {
        background: #005500;
        color: #00ff00;
        border: 1px solid #00ff00;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-family: inherit;
        font-weight: bold;
      }
      button:hover {
        background: #00ff00;
        color: #0d0d0d;
      }
      /* Login overlay */
      #login-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        justify-content: center;
        align-items: center;
        z-width: 1000;
      }
      .login-box {
        background: #1a1a1a;
        padding: 2rem;
        border: 1px solid #00ff00;
        text-align: center;
      }
      .login-box input {
        border: 1px solid #00ff00;
        padding: 0.5rem;
        margin: 0.5rem 0;
        display: block;
        width: 100%;
      }
    </style>
  </head>
  <body>
    <nav class="navbar">
      <div class="logo">⚡ Magic Agent Terminal</div>
      <div class="nav-links">
        <a href="/">← Back to HomeBase</a>
      </div>
    </nav>

    <div id="login-overlay">
      <div class="login-box">
        <h2>Authentication Required</h2>
        <p>Enter your admin credentials.</p>
        <input type="text" id="username" placeholder="Username (admin)" />
        <input type="password" id="password" placeholder="Password (admin)" />
        <button id="login-btn">Initialize Connection</button>
        <p id="login-error" class="message error" style="display: none;">Access Denied.</p>
      </div>
    </div>

    <div class="terminal-container" id="terminal">
      <div class="message agent">System initialized. Connected to Azure AI Backend (GPT-4o-mini).</div>
      <div class="message agent">Available modules: System Time, Local FS Read, Directory Search, PowerShell Execution.</div>
      <div class="message agent">Awaiting command...</div>
    </div>

    <div class="input-area">
      <span style="color: #00bfff;">PS C:\></span>
      <input type="text" id="chat-input" placeholder="Type a command or question..." autocomplete="off" autofocus />
      <button id="send-btn">EXECUTE</button>
    </div>

    <script>
      import { ApiClient } from '../lib/api';

      const loginOverlay = document.getElementById('login-overlay');
      const terminal = document.getElementById('terminal');
      const chatInput = document.getElementById('chat-input') as HTMLInputElement;
      const sendBtn = document.getElementById('send-btn');
      
      // Auto-hide login if already authenticated
      if (ApiClient.isAuthenticated()) {
        loginOverlay.style.display = 'none';
      }

      document.getElementById('login-btn').addEventListener('click', async () => {
        const u = (document.getElementById('username') as HTMLInputElement).value;
        const p = (document.getElementById('password') as HTMLInputElement).value;
        const success = await ApiClient.login(u, p);
        if (success) {
          loginOverlay.style.display = 'none';
          appendMessage('agent', 'Authentication successful. Access granted.');
        } else {
          document.getElementById('login-error').style.display = 'block';
        }
      });

      function appendMessage(sender: 'user' | 'agent' | 'error', text: string) {
        const div = document.createElement('div');
        div.className = `message ${sender}`;
        div.textContent = sender === 'user' ? `> ${text}` : text;
        terminal.appendChild(div);
        terminal.scrollTop = terminal.scrollHeight;
      }

      async function sendMessage() {
        const text = chatInput.value.trim();
        if (!text) return;

        appendMessage('user', text);
        chatInput.value = '';
        chatInput.disabled = true;
        sendBtn.textContent = 'EXECUTING...';

        try {
          const response = await ApiClient.chat(text);
          appendMessage('agent', response.reply);
        } catch (err) {
          appendMessage('error', `FATAL ERROR: ${err.message}`);
          if (err.message === 'Unauthorized') {
             loginOverlay.style.display = 'flex';
          }
        } finally {
          chatInput.disabled = false;
          sendBtn.textContent = 'EXECUTE';
          chatInput.focus();
        }
      }

      sendBtn.addEventListener('click', sendMessage);
      chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessage();
      });
    </script>
  </body>
</html>