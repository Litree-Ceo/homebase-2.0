# Development Dockerfile for FastAPI with uv
# Features: Hot reload, fast dependency sync

FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /app

# Enable bytecode compilation
ENV UV_COMPILE_BYTECODE=1

# Copy dependency files
COPY pyproject.toml uv.lock ./

# Install dependencies (including dev dependencies for testing)
RUN uv sync --frozen --no-cache --compile-bytecode

# Make sure we use the venv
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1

# Copy application code
COPY main.py ./

# Expose port
EXPOSE 8000

# Run with hot reload enabled
CMD ["uv", "run", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app"]
