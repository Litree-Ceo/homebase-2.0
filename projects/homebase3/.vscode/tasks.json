        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "docker-logs",
      "type": "shell",
      "command": "docker compose logs -f",
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
