rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow read: if request.auth != null && get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Game deals (public read, admin write)
    match /deals/{dealId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Revenue tracking (owner read, system write)
    match /revenue/{docId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if request.auth != null;
    }
    
    // WebRTC signaling (authenticated only)
    match /webrtc_calls/{callId} {
      allow read, write: if request.auth != null;
    }
    
    // Bot logs (owner read, bot write)
    match /bot_logs/{logId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if true; // Bots use service account
    }
    
    // Affiliate tracking
    match /affiliates/{affiliateId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if true; // Webhooks use service account
    }
  }
}
