# HomeBase 2.0 Root Environment Variables
# Copy these to apps/web/.env.local for local development

# Azure / API
COSMOS_ENDPOINT=
COSMOS_KEY=
SIGNALR_CONNECTION_STRING=
GROK_API_KEY=

# Database (MySQL wire protocol: works with MySQL, MariaDB, TiDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=homebase_app
DB_PASSWORD=homebase_app_pw
DB_NAME=homebase
DB_POOL_SIZE=5
