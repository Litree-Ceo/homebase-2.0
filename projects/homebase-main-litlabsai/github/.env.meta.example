# Meta Integration Environment Configuration
# Created: January 2026
# Purpose: Configure Facebook/Instagram Graph API integration

# ═══════════════════════════════════════════════════════════════
# Meta Application Settings
# ═══════════════════════════════════════════════════════════════

# Your Meta App ID (public - can be in client-side code)
NEXT_PUBLIC_META_APP_ID=YOUR_APP_ID_HERE

# Your Meta App Secret (KEEP SECRET - server only)
META_APP_SECRET=YOUR_APP_SECRET_HERE

# API Version (current as of January 2026)
NEXT_PUBLIC_META_API_VERSION=v18.0

# ═══════════════════════════════════════════════════════════════
# Authentication & Tokens
# ═══════════════════════════════════════════════════════════════

# Facebook Page Access Token (for posting and management)
# Get from: https://developers.facebook.com/tools/accesstoken/
META_PAGE_ACCESS_TOKEN=YOUR_PAGE_ACCESS_TOKEN_HERE

# Instagram Business Account Access Token (same as page token)
# Can be the same as META_PAGE_ACCESS_TOKEN
META_INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_ACCESS_TOKEN_HERE

# Optional: Client-side access token (not recommended for sensitive operations)
NEXT_PUBLIC_META_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════
# Webhook Configuration
# ═══════════════════════════════════════════════════════════════

# Webhook verify token (created by you - must match Meta app webhook settings)
# This is used to verify that webhooks coming from Meta are legitimate
META_WEBHOOK_VERIFY_TOKEN=YOUR_WEBHOOK_VERIFY_TOKEN_HERE

# Webhook URL (where Meta sends real-time updates)
# Must be HTTPS in production
META_WEBHOOK_URL=https://yourdomain.com/api/webhooks/meta

# ═══════════════════════════════════════════════════════════════
# Account Identifiers
# ═══════════════════════════════════════════════════════════════

# Your Instagram Business Account ID
# Format: numeric string like "17841400000000001"
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=YOUR_INSTAGRAM_BUSINESS_ACCOUNT_ID

# Your Facebook Page ID
# Format: numeric string like "123456789012345"
META_FACEBOOK_PAGE_ID=YOUR_FACEBOOK_PAGE_ID

# Your Meta Business Account ID (optional, for multi-account support)
META_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID

# ═══════════════════════════════════════════════════════════════
# NextAuth Configuration (if using NextAuth for Meta OAuth)
# ═══════════════════════════════════════════════════════════════

# NextAuth secret for session encryption
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE

# NextAuth URL (your app's base URL)
NEXTAUTH_URL=http://localhost:3000

# For production
# NEXTAUTH_URL=https://yourdomain.com

# ═══════════════════════════════════════════════════════════════
# OAuth Callback URLs
# ═══════════════════════════════════════════════════════════════

# These must match what you configure in Meta App Dashboard
META_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/meta/callback
META_OAUTH_CALLBACK_URL_PROD=https://yourdomain.com/api/auth/meta/callback

# ═══════════════════════════════════════════════════════════════
# Redirect URIs (for Meta Facebook Login)
# ═══════════════════════════════════════════════════════════════

# Add both to Meta App Dashboard > Settings > Facebook Login > Valid OAuth Redirect URIs
# http://localhost:3000/api/auth/meta/callback
# https://yourdomain.com/api/auth/meta/callback

# ═══════════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════════

# Enable Meta integration
NEXT_PUBLIC_ENABLE_META_INTEGRATION=true

# Enable Instagram integration
NEXT_PUBLIC_ENABLE_INSTAGRAM=true

# Enable Facebook Pages integration
NEXT_PUBLIC_ENABLE_FACEBOOK_PAGES=true

# Enable webhooks
NEXT_PUBLIC_ENABLE_META_WEBHOOKS=true

# ═══════════════════════════════════════════════════════════════
# Instructions for Getting These Values
# ═══════════════════════════════════════════════════════════════

# 1. Create Meta App:
#    - Go to https://developers.facebook.com/
#    - Create new Business app
#    - Get App ID and App Secret from Settings > Basic
#
# 2. Set Up OAuth:
#    - Add "Facebook Login" product
#    - Configure redirect URIs to http://localhost:3000/api/auth/meta/callback
#
# 3. Get Access Token:
#    - Go to https://developers.facebook.com/tools/accesstoken/
#    - Select your app
#    - Click "Get Token" for your Facebook page
#    - Copy token value
#
# 4. Get Instagram Business Account ID:
#    - Use Graph API Explorer
#    - Run: GET /me/instagram_business_accounts
#    - Copy ID from response
#
# 5. Create Webhook Token:
#    - Choose any secure string (min 8 characters)
#    - Example: "secure_webhook_token_12345"
#
# 6. Set Up Webhooks:
#    - In Meta App Dashboard > Products > Webhooks
#    - Callback URL: https://yourdomain.com/api/webhooks/meta
#    - Verify Token: (use your META_WEBHOOK_VERIFY_TOKEN value)
#    - Subscribe to: feed, comments, likes, messages
#
# See docs/META_ENV_SETUP.md for detailed step-by-step instructions
