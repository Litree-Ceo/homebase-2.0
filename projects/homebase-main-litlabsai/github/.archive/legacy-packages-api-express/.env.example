# Database (MySQL wire protocol: works with MySQL, MariaDB, TiDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=homebase_app
DB_PASSWORD=homebase_app_pw
DB_NAME=homebase
DB_POOL_SIZE=5

# Azure Key Vault (secure credential storage)
# Credentials are retrieved at runtime - do NOT store secrets here
KEY_VAULT_URL=https://kvprodlitree14210.vault.azure.net/

# Paddle Payment Integration
# Note: PaddleApiKey and PaddleWebhookSecret are stored in Key Vault
PADDLE_API_URL=https://api.paddle.com/v1
FRONTEND_URL=http://localhost:3000

# SignalR Configuration
SIGNALR_URL=http://localhost:3000/hub

# Environment
NODE_ENV=development
PORT=5001
