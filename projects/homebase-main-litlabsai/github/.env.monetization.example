# Monetization & Affiliate Configuration
# Add these to your .env files for complete monetization setup

# ============================================================================
# MUSIC STREAMING AFFILIATES
# ============================================================================

# Spotify Affiliate Program
# Sign up: https://affiliates.spotify.com
NEXT_PUBLIC_SPOTIFY_AFFILIATE_ID=your_spotify_affiliate_id
SPOTIFY_AFFILIATE_SECRET=your_spotify_secret

# Apple Music Affiliate
# Sign up: https://music.apple.com/affiliates
NEXT_PUBLIC_APPLE_MUSIC_AFFILIATE_ID=your_apple_music_id
APPLE_MUSIC_AFFILIATE_SECRET=your_apple_secret

# Bandcamp Affiliate
# https://bandcamp.com/affiliates
NEXT_PUBLIC_BANDCAMP_AFFILIATE_ID=your_bandcamp_id

# DistroKid Affiliate
# https://distrokid.com/affiliates
NEXT_PUBLIC_DISTROKID_AFFILIATE_ID=your_distrokid_id

# SoundCampaign Affiliate
# https://soundcampaign.com/affiliates
NEXT_PUBLIC_SOUND_CAMPAIGN_AFFILIATE_ID=your_sound_campaign_id

# Foximusic Affiliate
# https://www.foximusic.com/affiliate-program/
NEXT_PUBLIC_FOXIMUSIC_AFFILIATE_ID=your_foximusic_id

# One Submit Music Affiliate
# https://www.one-submit.com/affiliate-music-program
NEXT_PUBLIC_ONE_SUBMIT_AFFILIATE_ID=your_one_submit_id

# SOUNDRAW AI Music Affiliate
# https://discover.soundraw.io/affiliate
NEXT_PUBLIC_SOUNDRAW_AFFILIATE_ID=your_soundraw_id

# Unchained Music Affiliate
# https://www.unchainedmusic.io/music-affiliate-program
NEXT_PUBLIC_UNCHAINED_MUSIC_AFFILIATE_ID=your_unchained_id

# Tuned Global Affiliate
# https://www.tunedglobal.com
NEXT_PUBLIC_TUNED_GLOBAL_API_KEY=your_tuned_global_api_key

# ============================================================================
# MOVIE/VIDEO STREAMING AFFILIATES
# ============================================================================

# YouTube API
# https://developers.google.com/youtube
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_AFFILIATE_ID=your_youtube_affiliate_id

# FlexOffers (Netflix, Hulu, Disney+, Amazon Prime)
# https://www.flexoffers.com/affiliate-programs/entertainment/music-movies-games/
NEXT_PUBLIC_FLEXOFFERS_AFFILIATE_ID=your_flexoffers_id

# MovieGoods Affiliate
# https://www.flexoffers.com/affiliate-programs/moviegoods-affiliate-program/
NEXT_PUBLIC_MOVIEGOODS_AFFILIATE_ID=your_moviegoods_id

# Maestro Video Distribution
# https://www.maestro.io
NEXT_PUBLIC_MAESTRO_AFFILIATE_ID=your_maestro_id

# ConcertCloud Affiliate
# https://concertcloud.io/affiliate-program
NEXT_PUBLIC_CONCERT_CLOUD_AFFILIATE_ID=your_concert_cloud_id

# ============================================================================
# UGC (User Generated Content) MONETIZATION
# ============================================================================

# Collabhouse Music Payment Platform
# https://www.collabhouse.com/monetize-music/influencers
NEXT_PUBLIC_COLLABHOUSE_AFFILIATE_ID=your_collabhouse_id

# Orfium UGC Services
# https://www.orfium.com/ugc-services/
ORFIUM_API_KEY=your_orfium_api_key

# AIR Media-Tech Affiliate
# https://air.io/en/ambassador-affiliate-programs
NEXT_PUBLIC_AIR_MEDIA_AFFILIATE_ID=your_air_media_id

# ============================================================================
# PAYMENT & SUBSCRIPTION MANAGEMENT
# ============================================================================

# Paddle (Primary Payment Processor)
# https://paddle.com
NEXT_PUBLIC_PADDLE_VENDOR_ID=your_vendor_id
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_client_token
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_webhook_secret

# Stripe (Alternative/Secondary)
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ============================================================================
# ANALYTICS & CONVERSION TRACKING
# ============================================================================

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=your_ga_tracking_id

# Affiliate Tracking Parameters
NEXT_PUBLIC_AFFILIATE_TRACKING_ID=your_tracking_id
NEXT_PUBLIC_AFFILIATE_CONVERSION_PIXEL=your_conversion_pixel_url

# ============================================================================
# COMMISSION RATES & BUSINESS LOGIC
# ============================================================================

# Default commission rates (can override per service)
NEXT_PUBLIC_DEFAULT_COMMISSION_RATE=0.15
NEXT_PUBLIC_MUSIC_COMMISSION_RATE=0.20
NEXT_PUBLIC_VIDEO_COMMISSION_RATE=0.10
NEXT_PUBLIC_UGC_COMMISSION_RATE=0.25

# Minimum payout threshold (in cents)
NEXT_PUBLIC_MIN_PAYOUT_THRESHOLD=5000

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable monetization features
NEXT_PUBLIC_ENABLE_AFFILIATES=true
NEXT_PUBLIC_ENABLE_SUBSCRIPTIONS=true
NEXT_PUBLIC_ENABLE_COMMISSIONS=true
NEXT_PUBLIC_ENABLE_REVENUE_SHARING=true

# Affiliate program status
NEXT_PUBLIC_AFFILIATE_PROGRAM_ACTIVE=true
NEXT_PUBLIC_SHOW_REVENUE_DASHBOARD=true
