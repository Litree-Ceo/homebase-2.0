{
  "scriptFile": "../dist/functions/bot-api.js",
  "bindings": [
    {
      "authLevel": "anonymous",
      "type": "httpTrigger",
      "direction": "in",
      "name": "req",
      "methods": ["get", "post"],
      "route": "bot-api"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "$return"
    }
  ]
}
