# NOTE: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser. Secrets MUST NOT have this prefix.
# Client-side (public) configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_GOOGLE_AI_API_KEY=your_google_ai_key
NEXT_PUBLIC_INFURA_ID=your_infura_project_id
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side secrets (DO NOT expose to client)
STRIPE_SECRET_KEY=sk_test_...
OPENAI_API_KEY=sk-...
PAYPAL_CLIENT_SECRET=your_paypal_secret
COINBASE_API_KEY=your_coinbase_key
AZURE_COSMOS_ENDPOINT=your_cosmos_endpoint
AZURE_COSMOS_KEY=your_cosmos_key
AZURE_STORAGE_CONNECTION_STRING=your_storage_connection
PINATA_API_KEY=your_pinata_key
PINATA_SECRET_KEY=your_pinata_secret
NODE_ENV=development
