# Overlord Unified Site - Environment Configuration
# =================================================
# This is an example file. Copy it to .env and fill in your actual values.

# --- System Settings ---
# Environment: 'development' or 'production'
FLASK_ENV=development

# Port for the web server
PORT=8080

# --- Security & Authentication ---
# A strong, randomly generated key for securing internal APIs.
# REQUIRED FOR PRODUCTION.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
OVERLORD_AUTH_TOKEN=dev-token-for-local-use-only

# --- Core Service Agents ---

# OpenRouter AI API Key (for AI chat feature)
# Get your key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE

# Real-Debrid API Key (for streaming and torrent management)
# Get your key from: https://real-debrid.com/apitoken
RD_API_KEY=YOUR_REALDEBRID_API_KEY_HERE

# OpenClaw Gateway URL (for Android device integration)
OPENCLAW_GATEWAY_URL=http://192.168.X.X:18789

# --- Optional Services ---

# Firebase Service Account (optional, for cloud data sync)
# Paste the entire contents of your service account JSON file here as a single line.
FIREBASE_CONFIG='{"type": "service_account", "project_id": "your-gcp-project-id", ...}'

# Firebase Realtime Database URL (required if using Firebase)
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Termux SSH Credentials (optional, for remote device management)
TERMUX_HOST=192.168.X.X
TERMUX_PORT=8022
TERMUX_USER=your_termux_username
TERMUX_PASS=your_termux_password
