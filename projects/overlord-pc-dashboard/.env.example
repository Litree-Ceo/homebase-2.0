# cspell:ignore dbname, firebaseapp, realdebrid, supabase, urlsafe
# ============================================
# OVERLORD PC DASHBOARD - ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================

# --- Server Binding ---
# Host to bind the server to (0.0.0.0 = all interfaces)
HOST=0.0.0.0
# Port for the main server (server.py)
PORT=8080

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

# --- JWT Signing Secret (FastAPI backend) ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be at least 32 characters
SECRET_KEY=change-me-in-production-use-a-strong-random-secret

# --- Dashboard API Key (Traditional backend - server.py) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 characters recommended
OVERLORD_API_KEY=your_api_key_here

# ============================================
# DATABASE
# ============================================

# --- SQLite (Default) ---
# DATABASE_URL=sqlite:///overlord.db

# --- PostgreSQL (Async - for FastAPI main.py) ---
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:password@localhost:5432/overlord_db
POSTGRES_URL=

# ============================================
# AI PROVIDERS
# ============================================

# --- Google Gemini ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- OpenRouter (100+ models) ---
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Groq (Fast inference) ---
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# --- OpenAI (GPT models) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Ollama (FREE Local AI) ---
# Local Ollama server - no API key needed!
# Ollama must be running (e.g., ollama serve)
# Download models: https://ollama.ai/library
OLLAMA_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================

# --- Discord Webhook Notifications ---
# Create a webhook in Discord Server Settings > Integrations
DISCORD_WEBHOOK_URL=

# --- Real-Debrid (Streaming/Torrent management) ---
# Get from: https://real-debrid.com/apitoken
REALDEBRID_API_TOKEN=

# --- Firebase Service Account ---
# Path to Firebase service account JSON file OR the JSON content itself
# Used for Firebase Admin SDK (Firestore, Realtime Database, etc.)
# Format: FIREBASE_CONFIG={"type":"service_account",...}
FIREBASE_CONFIG=

# ============================================
# MOBILE DEVELOPMENT (Termux SSH)
# ============================================

# SSH connection to Termux on Android for remote development
TERMUX_HOST=localhost
TERMUX_PORT=8022
TERMUX_USER=termux
TERMUX_PASS=

# ============================================
# CLIENT-SIDE CONFIG (Astro/React Frontend)
# ============================================
# These are prefixed with PUBLIC_ to be exposed to the browser

# --- Site URLs ---
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:8001

# --- Supabase (Authentication) ---
# Get from: https://supabase.com/dashboard/project/{project}/settings/api
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- Firebase (Authentication) ---
# Get from: Firebase Console > Project Settings > General
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=

# ============================================
# DEVELOPMENT OPTIONS
# ============================================

# Set to 'true' to enable debug logging
# DEBUG=false

# Set to 'production' for production deployment
# NODE_ENV=development
