---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="404: Not Found">
  <div class="text-center">
    <h1 class="text-4xl font-bold">404 - Page Not Found</h1>
    <p class="mt-4">The resource you requested could not be located.</p>
    <a href="/" class="mt-8 inline-block px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700">Return to Dashboard</a>
  </div>
</MainLayout>
