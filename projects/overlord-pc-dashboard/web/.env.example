# See instructions in README.md to set up your database and get these values.
# You can get them from your Supabase project settings.

# --- DATABASE (PostgreSQL) ---
# Used by the Python backend to connect to your database.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres"

# --- SUPABASE (Authentication & Frontend Access) ---
# These are safe to be public and are used by the frontend to talk to Supabase.
PUBLIC_SUPABASE_URL="[YOUR-SUPABASE-PROJECT-URL]"
PUBLIC_SUPABASE_ANON_KEY="[YOUR-SUPABASE-ANON-KEY]"

# This is a secret key for backend to perform admin-level actions.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SUPABASE-SERVICE-ROLE-KEY]"

# --- AI & SECURITY --- 
# Your OpenRouter key for the AI Assistant.
OPENROUTER_API_KEY="[YOUR-OPENROUTER-KEY]"

# The AI model to be used in the chat.
AI_MODEL="openai/gpt-4o"

# A secret key used to sign JWTs for secure API communication.
# Generate a long, random string for this (e.g., using a password manager).
API_SECRET_KEY="[YOUR-STRONG-SECRET-KEY]"

# --- DEPLOYMENT ---
# The public URL of your deployed site.
SITE_URL="http://localhost:4321"
