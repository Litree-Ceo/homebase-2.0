# ============================================
# Overlord Modern - Environment Configuration
# ============================================

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Security
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here_change_in_production

# Database
DATABASE_URL=sqlite+aiosqlite:///./overlord.db

# CORS (Frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# AI ASSISTANT - ZERO COST (100% FREE)
# ============================================

