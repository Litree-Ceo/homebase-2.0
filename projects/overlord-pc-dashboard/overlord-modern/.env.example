# Overlord PC Dashboard - Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_PASSWORD=change_this_to_secure_password

# Security (Generate secure random values for production)
SECRET_KEY=your-secret-key-here-min-32-chars
API_KEY=ovrd_your-api-key-here
WEBSOCKET_TOKEN=ws_your-websocket-token-here

# Optional: Real-Debrid Integration
# RD_API_KEY=your_realdebrid_api_key

# Optional: Firebase
# FIREBASE_CONFIG={...}
