{
    "git.ignoreLimitWarning": true,
    
    // OpenAI Configuration
    "openai.apiKey": "${env:OPENAI_API_KEY}",
    "vscode-openai.apiKey": "${env:OPENAI_API_KEY}",
    "chatgpt.apiKey": "${env:OPENAI_API_KEY}",
    
    // OpenAI Embedding Model Configuration
    "vscode-openai.embeddingModel.apiKey": "${env:OPENAI_API_KEY}",
    "vscode-openai.embeddingModel.enabled": true,
    "chatgpt.openOnStartup": false,
    
    // Microsoft Edge DevTools Configuration
    "vscode-edge-devtools.browserFlavor": "Default",
    "vscode-edge-devtools.hostname": "localhost",
    "vscode-edge-devtools.port": 9222,
    "vscode-edge-devtools.useHttps": false,
    "vscode-edge-devtools.defaultUrl": "https://www.youtube.com",
    "vscode-edge-devtools.webRoot": "${workspaceFolder}",
    
    // Simple Browser Configuration
    "simpleBrowser.focusLockIndicator.enabled": false,
    
    // Browse Lite - YouTube Guest Mode
    "browse-lite.startUrl": "https://m.youtube.com",
    "browse-lite.browser": "chrome",
    "browse-lite.chromeArgs": [
        "--incognito",
        "--disable-web-security",
        "--disable-features=IsolateOrigins,site-per-process",
        "--user-agent=Mozilla/5.0 (Linux; Android 10) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.120 Mobile Safari/537.36"
    ]
}