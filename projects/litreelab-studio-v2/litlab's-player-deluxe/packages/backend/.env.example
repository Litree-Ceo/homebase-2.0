# Flask Agent — Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# REQUIRED: Core Security Settings
# ═══════════════════════════════════════════════════════════════

# Security secret for authenticating requests from Blazor
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
OVERLORD_SECRET=changeme-generated-secret-key

# ═══════════════════════════════════════════════════════════════
# REQUIRED: AI Service Settings
# ═══════════════════════════════════════════════════════════════

# OpenRouter API Key for AI Explain and Planning
# Get yours from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
