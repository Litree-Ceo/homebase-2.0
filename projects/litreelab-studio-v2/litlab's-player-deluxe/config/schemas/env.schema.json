{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Overlord PC Dashboard Environment Variables",
  "description": "Schema for validating environment variables",
  "type": "object",
  "required": ["API_KEY"],
  "properties": {
    "API_KEY": {
      "type": "string",
      "description": "Dashboard API key for authentication",
      "minLength": 16,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "OVERLORD_AUTH_TOKEN": {
      "type": "string",
      "description": "WebSocket bridge authentication token",
      "minLength": 32
    },
    "RD_API_KEY": {
      "type": "string",
      "description": "Real-Debrid API key for streaming features"
    },
    "FIREBASE_CONFIG": {
      "type": "string",
      "description": "Firebase service account JSON configuration"
    },
    "FIREBASE_DATABASE_URL": {
      "type": "string",
      "description": "Firebase Realtime Database URL",
      "format": "uri"
    },
    "NODE_ENV": {
      "type": "string",
      "description": "Node.js environment mode",
      "enum": ["development", "production", "test"],
      "default": "development"
    },
    "PYTHONPATH": {
      "type": "string",
      "description": "Python module search path",
      "default": "."
    }
  },
  "additionalProperties": true
}
