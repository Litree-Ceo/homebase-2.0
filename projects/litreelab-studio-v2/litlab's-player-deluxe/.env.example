# Overlord PC Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# .env values override config.yaml settings

# ═══════════════════════════════════════════════════════════════
# REQUIRED: Core Security Settings
# ═══════════════════════════════════════════════════════════════

# Dashboard API Key (32+ characters recommended)
# This key is required to access protected endpoints like /api/stats
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=changeme-generated-api-key

# Overlord Bridge Authentication Token (required for websocket bridge)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
OVERLORD_AUTH_TOKEN=changeme-generated-auth-token

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Third-Party Integrations
# ═══════════════════════════════════════════════════════════════

# Real-Debrid API Key (for streaming/torrent features)
# Get yours from: https://real-debrid.com/apitoken
RD_API_KEY=your_realdebrid_api_key_here

# Firebase Configuration (for cloud sync)
# Copy your Firebase service account JSON string here or leave empty
FIREBASE_CONFIG=

# Firebase Database URL (if using Firebase)
# Example: https://your-project-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=

# Termux SSH Connection
TERMUX_HOST=
TERMUX_PORT=8022
TERMUX_USER=
TERMUX_PASS=

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here


# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Development Settings
# ═══════════════════════════════════════════════════════════════

# Node environment (development/production)
NODE_ENV=development

# Python path configuration
PYTHONPATH=.
