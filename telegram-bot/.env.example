# ============================================
# Telegram Bot Configuration
# Get from @BotFather on Telegram
# ============================================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ============================================
# Firebase Configuration (for database/logging)
# Get from: https://console.firebase.google.com
# Project Settings > Service Accounts > Generate New Private Key
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_multi_line_key_here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ============================================
# AI Configuration - GROQ (BEST FREE TIER)
# Sign up: https://groq.com (free, no credit card required)
# API Keys > Create Key
# ============================================
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Choose model (defaults to llama-3.1-8b-instant)
# Available free models:
# - llama-3.1-8b-instant (fastest, best for bots)
# - llama-3.3-70b-versatile (smarter, slightly slower)
# - mixtral-8x7b-32768 (good for long contexts)
GROQ_MODEL=llama-3.1-8b-instant

# Optional: Max tokens for responses (lower = faster + cheaper)
MAX_TOKENS=150

# ============================================
# Optional Features
# ============================================
# Admin Telegram username (for admin commands)
ADMIN_USERNAME=your_telegram_username

# Log level (debug, info, warn, error)
LOG_LEVEL=info
